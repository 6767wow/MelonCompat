{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RoseV IDE",
  "version": "0.1.0",
  "identifier": "dev.jayde.rosev.ide",
  "build": {
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RoseV IDE",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
